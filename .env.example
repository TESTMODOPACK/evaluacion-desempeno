# ============================================================
# EVALUACIÓN DE DESEMPEÑO — Variables de Entorno
# Copia este archivo a .env y completa los valores
# NUNCA commitear .env con secretos reales
# ============================================================

# ----- Base de Datos -----
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/evaluacion_desempeno?schema=public"

# ----- Redis -----
REDIS_URL="redis://localhost:6379"

# ----- JWT (Auth) -----
JWT_SECRET="CAMBIA_ESTO_EN_PRODUCCION_min32chars_secreto"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="CAMBIA_ESTO_TAMBIEN_EN_PRODUCCION_refresh_secreto"
JWT_REFRESH_EXPIRES_IN="7d"

# ----- OIDC / OAuth2 (Phase 2 — dejar vacío para usar JWT local) -----
OIDC_ISSUER=""
OIDC_CLIENT_ID=""
OIDC_CLIENT_SECRET=""
OIDC_REDIRECT_URI="http://localhost:3001/api/v1/auth/callback"

# ----- SAML (Phase 2 — stub) -----
SAML_ENTRY_POINT=""
SAML_ISSUER=""
SAML_CERT=""

# ----- App Config -----
NODE_ENV="development"
PORT=3001
API_URL="http://localhost:3001"
WEB_URL="http://localhost:3002"
CORS_ORIGINS="http://localhost:3002"

# ----- Email (SMTP) -----
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="noreply@modopack.com"

# ----- Slack (Phase 2 — dejar vacío) -----
SLACK_BOT_TOKEN=""
SLACK_SIGNING_SECRET=""

# ----- Microsoft Teams (Phase 2 — dejar vacío) -----
TEAMS_WEBHOOK_URL=""

# ----- Observabilidad -----
OTEL_SERVICE_NAME="evaluacion-desempeno-api"
OTEL_EXPORTER_OTLP_ENDPOINT="http://localhost:4317"
SENTRY_DSN=""

# ----- Seguridad -----
BCRYPT_ROUNDS=12
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# ----- Exports / Storage -----
EXPORT_STORAGE_PATH="./exports"

# ----- Frontend (Next.js — prefijo NEXT_PUBLIC_ para exponer al browser) -----
NEXT_PUBLIC_API_URL="http://localhost:3001/api/v1"
NEXT_PUBLIC_APP_NAME="EvalDesempeño"
NEXT_PUBLIC_SENTRY_DSN=""
